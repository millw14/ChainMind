# ChainMind — AI explorer for Robinhood Chain.
# Copy to `.env.local`; never commit real values.

# --- Groq (LLM) — REQUIRED to answer questions. https://console.groq.com/ ---
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile). A smaller model
# such as llama-3.1-8b-instant uses fewer tokens per day on the free tier.
# GROQ_MODEL=

# --- Robinhood Chain (EVM L2) ---
# Network selector: mainnet (chain 4663) | testnet (chain 46630). Default: mainnet.
# ROBINHOOD_NETWORK=mainnet
# Optional dedicated RPC (QuickNode / Chainstack / Alchemy) for higher rate
# limits. Falls back to the public RPC when unset.
# ROBINHOOD_RPC_URL=

# --- Alchemy (OPTIONAL) — all three unset = public RPC, which works fine ---
# Precedence: ROBINHOOD_RPC_URL > ALCHEMY_RPC_URL > template+key > public RPC.
# Preferred: paste the full endpoint URL from the Alchemy dashboard (it already
# contains the key). Used verbatim, so no hostname is ever guessed for you.
# ALCHEMY_RPC_URL=
# Alternative: keep the key out of the URL. BOTH of these must be set — the
# template supplies the host Alchemy assigns to Robinhood Chain, `{key}` is
# replaced by ALCHEMY_API_KEY (no placeholder = key appended as a path segment).
# ALCHEMY_RPC_TEMPLATE=https://<alchemy-host-for-chain-4663>/v2/{key}
# ALCHEMY_API_KEY=

# --- Blockscout (indexer / explorer) ---
# Override the indexer host or add a Pro key to raise rate limits. Defaults to
# the public Robinhood Chain Blockscout instance.
# BLOCKSCOUT_API_URL=https://robinhoodchain.blockscout.com/api
# BLOCKSCOUT_API_KEY=

# Optional: how long the in-memory tokenized-equity list is reused before the
# token pages are walked again. Milliseconds; default 300000 (5 min). 0 disables
# the cache (every request re-walks Blockscout — only useful for debugging).
# STOCK_CACHE_TTL_MS=300000

# Stable origin for self-calls / metadata (optional; recommended on Vercel).
# Also accepted as a same-origin Origin by the /api/ask abuse guard.
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
