# ChainMind — Solana focus. Copy to `.env.local`; never commit real values.

# Dashboard / cron: stable origin for self-calls (recommended on Vercel if previews use wrong VERCEL_URL)
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Vercel Cron: required for GET /api/cron/analyst-sweep (Vercel sends Authorization: Bearer CRON_SECRET)
# CRON_SECRET=generate-a-long-random-string

# Operator Bearer token for write/expensive API routes (groq-brief source=auto/webhook/cache,
# cases force/autoGroq, db-stats per-scope breakdown). Without it, callers must look like the
# same-origin browser dashboard (Sec-Fetch-Site / Origin vs NEXT_PUBLIC_APP_URL) and are rate limited.
# The dashboard's "Operator key" field sends this value (kept in localStorage as cm_operator_key).
# CHAINMIND_OPERATOR_SECRET=generate-a-long-random-string

# Scope for scheduled analyst (overrides CHAINMIND_SCOPE for cron only if set)
# CHAINMIND_CRON_SCOPE=
# Optional overrides for cron score/inspect (defaults match dashboard-ish)
# CHAINMIND_CRON_SCORE_WINDOW=5
# CHAINMIND_CRON_SCORE_HOURS=168
# CHAINMIND_CRON_INSPECT_LIMIT=12
SOLANA_RPC_URL=

# When SOLANA_RPC_URL is unset, clusterApiUrl() uses this (mainnet-beta | devnet | testnet)
SOLANA_CLUSTER=mainnet-beta

# Wallet first signature (chain-backed age) → Turso `wallet_first_seen`. Run: npm run wallet-age:backfill -- <addr> ...
# Optional: lazy-fill missing rows during GET /api/score (needs SOLANA_RPC_URL; adds RPC latency)
# CHAINMIND_FETCH_WALLET_AGE_ON_SCORE=1
# CHAINMIND_WALLET_AGE_MAX_FETCH=3
# CHAINMIND_WALLET_AGE_MAX_PAGES=5

# Groq (LLM). https://console.groq.com/
GROQ_API_KEY=

# Auto analyst: POST high-confidence verdicts (source=auto, confidence > threshold) — optional
# CHAINMIND_VERDICT_WEBHOOK_URL=https://hooks.slack.com/services/...
# Optional Bearer for webhook receiver
# CHAINMIND_VERDICT_WEBHOOK_SECRET=
# Min model confidence to POST webhook (default 0.7)
# CHAINMIND_WEBHOOK_MIN_CONFIDENCE=0.7

# Legacy alias for CHAINMIND_OPERATOR_SECRET accepted only by POST /api/groq-brief
# GROQ_BRIEF_SECRET=

# Per-IP requests/minute for unauthenticated POST /api/groq-brief (fail-closed; default 6)
# CHAINMIND_GROQ_BRIEF_RATE_LIMIT_PER_MIN=6

# Optional Groq model id (default: llama-3.3-70b-versatile)
# GROQ_MODEL=
# Smaller / faster models use fewer tokens per day on free tier, e.g. llama-3.1-8b-instant

# Verdict cache: skip a Groq call when a recent analysis for the same scope and
# unchanged evidence already exists. Hours within which to reuse (default 6; 0 disables).
# Applies to non-interactive sources (auto / auto_investigation_case / case). Requires Turso.
# CHAINMIND_GROQ_REANALYZE_MIN_HOURS=6

# Optional alias for GROQ_API_KEY:
# GEOQ_API_KEY=

# Local SQLite DB path (default: data/chainmind.db)
# DATABASE_PATH=data/chainmind.db

# Default address for inspect/backfill when you do not pass argv
# TARGET_ADDRESS=

# Primary analysis scope (same as a mint / wallet / program pubkey you track)
# CHAINMIND_SCOPE=

# Multi-scope pipeline: path to JSON watchlist (default config/watchlist.json)
# CHAINMIND_WATCHLIST=config/watchlist.json

# Vercel / serverless: JSON watchlist when config/watchlist.json is not deployed (string value)
# CHAINMIND_WATCHLIST_JSON={"scopes":[{"address":"EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v","note":"USDC"}]}

# Autonomous surface scan (GET /api/cron/surface-scan + Turso surface_hits + dashboard feed)
# SURFACE_SCORE_WINDOW=5
# SURFACE_SCORE_HOURS=168
# SURFACE_INSPECT_LIMIT=12
# SURFACE_EVENT_SPIKE_MULT=3
# SURFACE_MIN_FUNDED_PAYERS=5
# SURFACE_DENSE_PAYER_MIN=14

# GET /api/cron/baseline-update — daily Turso `scope_baselines` (vercel.json ~03:45 UTC; Authorization: Bearer CRON_SECRET)
# BASELINE_WINDOW_MINUTES=5
# BASELINE_LOOKBACK_HOURS=168

# pipeline-worker: run `npm run baseline:update --force` at most once per 24h (stamp: data/.pipeline-baseline-last)
# PIPELINE_BASELINE_DAILY=1

# Helius token watchlist scanner (local/VPS: npm run helius-scan). Uses SQLite + RPC — not for Vercel functions.
# Curated mints showing early activity; DexScreener supplies m5/h24 volume; Helius DAS supplies USD price.
# HELIUS_API_KEY=
# CHAINMIND_HELIUS_SCAN_MINTS_JSON=["So11111111111111111111111111111111111111112"]
# HELIUS_SCAN_INTERVAL_MS=60000
# HELIUS_SCAN_VOLUME_SPIKE_MULT=3
# HELIUS_SCAN_PRICE_DELTA_PCT=0.08
# HELIUS_SCAN_DS_M5_ABS_PCT=8
# HELIUS_SCAN_MIN_M5_USD=0
# HELIUS_SCAN_TOP_HOLDERS=8
# HELIUS_SCAN_MINT_HEAD_MAX=500
# HELIUS_SCAN_WALLET_HEAD_MAX=120
# HELIUS_SCAN_INGEST_LIMIT=25
# HELIUS_SCAN_DEXSCREENER_GAP_MS=1100
# HELIUS_SCAN_BASELINE_PATH=data/helius-scan-baseline.json
# HELIUS_SCAN_QUEUE_PATH=data/helius-investigation-queue.jsonl

# pipeline-worker: milliseconds between full rounds (default 90000)
# PIPELINE_ROUND_MS=90000

# pipeline-worker backlog guard: when a scope has more than this many unparsed signatures,
# pause head-poll discovery for it that round and spend the budget parsing (parse-first), so
# discovery can't outrun parsing and grow the backlog without bound. 0 disables. Default 500.
# PIPELINE_BACKLOG_PAUSE=500

# Token discovery: auto-enqueue trending Solana mints (DexScreener free API) so detection
# isn't limited to the static watchlist. The worker processes EVERY active scope per round,
# so MAX_ACTIVE_SCOPES bounds total load. Disable with DISCOVERY_ENABLED=0.
# DISCOVERY_ENABLED=1
# MAX_ACTIVE_SCOPES=10          # hard cap on scopes the worker tracks (watchlist + queued + discovered)
# DISCOVERY_PER_CYCLE=3         # mints to discover per discovery cycle
# DISCOVERY_EVERY_ROUNDS=4      # run discovery every N rounds

# turso sync: rows per Turso pipeline request during sqlite→Turso mirror (default 100).
# Sync is incremental (only rows newer than Turso's high-water mark) and streamed.
# TURSO_SYNC_BATCH=100

# scan_queue: reclaim an 'active' row if the worker hasn't re-picked it within this many
# seconds (recovers ghost jobs left behind when a worker dies mid-round). Default 3600 (1h).
# SCAN_QUEUE_STALE_ACTIVE_SECONDS=3600

# Backfill: set to 1 with npm run backfill -- <addr> --resume to continue deep pagination
# BACKFILL_RESUME=

# ingest-events / pipeline parse budget per scope per round (default 60). Raising this drains
# backlog faster but each tx costs one getParsedTransaction RPC + INGEST_THROTTLE_MS. If your
# RPC tier allows, LOWERING the throttle is the biggest lever to clear a large backlog.
# INGEST_PARSE_LIMIT=60
# INGEST_THROTTLE_MS=900

# Known-entity allowlist: addresses whose activity is NOT token coordination
# (CEX hot wallets, market makers, launchpad fee wallets, bridges). Excluded as
# funders, co-activity payers, and wash counterparties. JSON array; verify each
# address first — wrongly allowlisting a real wallet hides coordination.
# CHAINMIND_KNOWN_ENTITIES_JSON=[{"address":"<base58>","label":"Binance hot","type":"exchange"}]

# parse-tx-graph: minimum lamports for inferred native funding edges (dust floor +
# amount-match basis). Below this, a fee-payer's gain or a candidate funder's loss is
# ignored. Default 1000000 (0.001 SOL). Raise to be stricter about what counts as funding.
# CHAINMIND_FUNDING_MIN_LAMPORTS=1000000

# score-window: bucket width (minutes) and lookback (hours)
# SCORE_WINDOW_MINUTES=5
# SCORE_LAST_HOURS=24

# Dashboard (Express) port
# PORT=3847

# Turso — optional cloud SQLite for Vercel (DB stats + score). https://turso.tech
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# GET /api/score: serve repeat searches + dashboard polls from the score_cache table
# instead of recomputing (cost + abuse control). TTL seconds; 0 disables caching.
# The dashboard's "Re-Analyze (fresh)" sends ?fresh=1 to bypass this and recompute.
# Requires schema/turso.sql tables `score_cache` + `rate_limit` (re-run npm run turso:schema).
# CHAINMIND_SCORE_CACHE_TTL_SEC=180
# Per-IP requests/minute for the public score endpoint (fixed-window; fail-open on error).
# CHAINMIND_RATE_LIMIT_PER_MIN=40

# Legacy alias for CHAINMIND_OPERATOR_SECRET accepted only by POST /api/cases
# CASE_CREATE_SECRET=generate-a-long-random-string
# Per-IP case creations/minute for unauthenticated POST /api/cases (default 3)
# CHAINMIND_CASE_RATE_LIMIT_PER_MIN=3

# Optional: cross-mint intel — ranked wallets fuse fee_payers + signers + transfer endpoints; pairwise overlap across watchlist mints.
# CROSS_MINT_TOP_PAYERS=18
# CROSS_MINT_MIN_CLUSTER=3
# Jaccard threshold (0–1) to merge a new cluster observation with an existing lineage (rotation tolerance). Default 0.45.
# CROSS_MINT_CLUSTER_MERGE_JACCARD=0.45
# Set to fee_only to disable signer + transfer ranking (legacy behavior).
# CROSS_MINT_RANK_SIGNALS=

# Vercel cron: analyst sweep — auto Groq when co-activity > threshold (see lib/groq-thresholds.js).
# Single scope: CHAINMIND_CRON_SCOPE or CHAINMIND_SCOPE.
# Watchlist-wide: set CHAINMIND_ANALYST_SWEEP_WATCHLIST=1 (uses CHAINMIND_WATCHLIST_JSON / config/watchlist.json).
# CHAINMIND_ANALYST_SWEEP_WATCHLIST=1
# ANALYST_SWEEP_MAX_SCOPES=8
# ANALYST_SWEEP_GROQ_DELAY_MS=350

# Apply schema/migrations/009_intel_cluster_canonical.sql on existing Turso DBs (adds canonical_cluster_id for cluster lineage).

# How many signatures inspect prints (max 100)
# INSPECT_LIMIT=15

# Backfill cap per run (max 5000)
# BACKFILL_MAX=200

# Off-site backups: Cloudflare R2 (S3-compatible) target for `npm run backup`.
# Create a bucket + Object Read&Write API token at dash.cloudflare.com → R2.
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_BUCKET=chainmindbackups
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
