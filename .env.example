# ChainMind — Solana focus. Copy to `.env.local`; never commit real values.

# Dashboard / cron: stable origin for self-calls (recommended on Vercel if previews use wrong VERCEL_URL)
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Vercel Cron: required for GET /api/cron/analyst-sweep (Vercel sends Authorization: Bearer CRON_SECRET)
# CRON_SECRET=generate-a-long-random-string

# Scope for scheduled analyst (overrides CHAINMIND_SCOPE for cron only if set)
# CHAINMIND_CRON_SCOPE=
# Optional overrides for cron score/inspect (defaults match dashboard-ish)
# CHAINMIND_CRON_SCORE_WINDOW=5
# CHAINMIND_CRON_SCORE_HOURS=168
# CHAINMIND_CRON_INSPECT_LIMIT=12
SOLANA_RPC_URL=

# When SOLANA_RPC_URL is unset, clusterApiUrl() uses this (mainnet-beta | devnet | testnet)
SOLANA_CLUSTER=mainnet-beta

# Wallet first signature (chain-backed age) → Turso `wallet_first_seen`. Run: npm run wallet-age:backfill -- <addr> ...
# Optional: lazy-fill missing rows during GET /api/score (needs SOLANA_RPC_URL; adds RPC latency)
# CHAINMIND_FETCH_WALLET_AGE_ON_SCORE=1
# CHAINMIND_WALLET_AGE_MAX_FETCH=3
# CHAINMIND_WALLET_AGE_MAX_PAGES=5

# Groq (LLM). https://console.groq.com/
GROQ_API_KEY=

# Auto analyst: POST high-confidence verdicts (source=auto, confidence > threshold) — optional
# CHAINMIND_VERDICT_WEBHOOK_URL=https://hooks.slack.com/services/...
# Optional Bearer for webhook receiver
# CHAINMIND_VERDICT_WEBHOOK_SECRET=
# Min model confidence to POST webhook (default 0.7)
# CHAINMIND_WEBHOOK_MIN_CONFIDENCE=0.7

# Optional: require Authorization: Bearer <secret> on POST /api/groq-brief
# GROQ_BRIEF_SECRET=

# Optional Groq model id (default: llama-3.3-70b-versatile)
# GROQ_MODEL=
# Smaller / faster models use fewer tokens per day on free tier, e.g. llama-3.1-8b-instant

# Optional alias for GROQ_API_KEY:
# GEOQ_API_KEY=

# Local SQLite DB path (default: data/chainmind.db)
# DATABASE_PATH=data/chainmind.db

# Default address for inspect/backfill when you do not pass argv
# TARGET_ADDRESS=

# Primary analysis scope (same as a mint / wallet / program pubkey you track)
# CHAINMIND_SCOPE=

# Multi-scope pipeline: path to JSON watchlist (default config/watchlist.json)
# CHAINMIND_WATCHLIST=config/watchlist.json

# Vercel / serverless: JSON watchlist when config/watchlist.json is not deployed (string value)
# CHAINMIND_WATCHLIST_JSON={"scopes":[{"address":"EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v","note":"USDC"}]}

# Autonomous surface scan (GET /api/cron/surface-scan + Turso surface_hits + dashboard feed)
# SURFACE_SCORE_WINDOW=5
# SURFACE_SCORE_HOURS=168
# SURFACE_INSPECT_LIMIT=12
# SURFACE_EVENT_SPIKE_MULT=3
# SURFACE_MIN_FUNDED_PAYERS=5
# SURFACE_DENSE_PAYER_MIN=14

# Helius token watchlist scanner (local/VPS: npm run helius-scan). Uses SQLite + RPC — not for Vercel functions.
# Curated mints showing early activity; DexScreener supplies m5/h24 volume; Helius DAS supplies USD price.
# HELIUS_API_KEY=
# CHAINMIND_HELIUS_SCAN_MINTS_JSON=["So11111111111111111111111111111111111111112"]
# HELIUS_SCAN_INTERVAL_MS=60000
# HELIUS_SCAN_VOLUME_SPIKE_MULT=3
# HELIUS_SCAN_PRICE_DELTA_PCT=0.08
# HELIUS_SCAN_DS_M5_ABS_PCT=8
# HELIUS_SCAN_MIN_M5_USD=0
# HELIUS_SCAN_TOP_HOLDERS=8
# HELIUS_SCAN_MINT_HEAD_MAX=500
# HELIUS_SCAN_WALLET_HEAD_MAX=120
# HELIUS_SCAN_INGEST_LIMIT=25
# HELIUS_SCAN_DEXSCREENER_GAP_MS=1100
# HELIUS_SCAN_BASELINE_PATH=data/helius-scan-baseline.json
# HELIUS_SCAN_QUEUE_PATH=data/helius-investigation-queue.jsonl

# pipeline-worker: milliseconds between full rounds (default 90000)
# PIPELINE_ROUND_MS=90000

# Backfill: set to 1 with npm run backfill -- <addr> --resume to continue deep pagination
# BACKFILL_RESUME=

# ingest-events: max signatures to parse per run
# INGEST_PARSE_LIMIT=40
# INGEST_THROTTLE_MS=900

# score-window: bucket width (minutes) and lookback (hours)
# SCORE_WINDOW_MINUTES=5
# SCORE_LAST_HOURS=24

# Dashboard (Express) port
# PORT=3847

# Turso — optional cloud SQLite for Vercel (DB stats + score). https://turso.tech
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# Optional: require Bearer token on POST /api/cases (frozen investigation snapshots)
# CASE_CREATE_SECRET=generate-a-long-random-string

# Optional: POST /api/cases runs Groq before freezing (same as dashboard brief). Override with body.autoGroq.
# CASE_AUTO_GROQ=1

# How many signatures inspect prints (max 100)
# INSPECT_LIMIT=15

# Backfill cap per run (max 5000)
# BACKFILL_MAX=200
