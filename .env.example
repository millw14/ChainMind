# ChainMind — Solana focus. Copy to `.env.local`; never commit real values.

# Dedicated Solana RPC (recommended for production: Helius, Triton, QuickNode, etc.)
SOLANA_RPC_URL=

# When SOLANA_RPC_URL is unset, clusterApiUrl() uses this (mainnet-beta | devnet | testnet)
SOLANA_CLUSTER=mainnet-beta

# Groq (LLM). https://console.groq.com/
GROQ_API_KEY=

# Optional: require Authorization: Bearer <secret> on POST /api/groq-brief
# GROQ_BRIEF_SECRET=

# Optional Groq model id (default: llama-3.3-70b-versatile)
# GROQ_MODEL=

# Optional alias for GROQ_API_KEY:
# GEOQ_API_KEY=

# Local SQLite DB path (default: data/chainmind.db)
# DATABASE_PATH=data/chainmind.db

# Default address for inspect/backfill when you do not pass argv
# TARGET_ADDRESS=

# Primary analysis scope (same as a mint / wallet / program pubkey you track)
# CHAINMIND_SCOPE=

# Multi-scope pipeline: path to JSON watchlist (default config/watchlist.json)
# CHAINMIND_WATCHLIST=config/watchlist.json

# pipeline-worker: milliseconds between full rounds (default 90000)
# PIPELINE_ROUND_MS=90000

# Backfill: set to 1 with npm run backfill -- <addr> --resume to continue deep pagination
# BACKFILL_RESUME=

# ingest-events: max signatures to parse per run
# INGEST_PARSE_LIMIT=40
# INGEST_THROTTLE_MS=900

# score-window: bucket width (minutes) and lookback (hours)
# SCORE_WINDOW_MINUTES=5
# SCORE_LAST_HOURS=24

# Dashboard (Express) port
# PORT=3847

# Turso — optional cloud SQLite for Vercel (DB stats + score). https://turso.tech
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# How many signatures inspect prints (max 100)
# INSPECT_LIMIT=15

# Backfill cap per run (max 5000)
# BACKFILL_MAX=200
