{
  "name": "chainmind",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "ChainMind — Solana-first coordination intelligence",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
